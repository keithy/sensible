[Unit]
Description=Sensible Queue Worker (user)
Documentation=https://github.com/keithy/sensible

[Service]
Type=oneshot
Environment=SENSIBLE_TASKS_DIR=%h/.local/share/sensible/tasks
ExecStart=%h/.local/bin/sensible consume
StandardOutput=journal
StandardError=journal
RefuseMultipleInstances=true

[Install]
WantedBy=default.target